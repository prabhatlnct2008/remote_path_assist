# ─────────────────────────────────────────────────────────────────────────────
# PathConsult environment variables. Copy to `.env` and fill in.
# `lib/env.ts` validates these at boot — a missing/invalid required var fails fast.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
# Public base URL of the app (used in emails, magic links, PDF audit footer).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth.js (v5) ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional; Auth.js infers from request in most deployments.
AUTH_URL=http://localhost:3000

# ── Database: Turso (libSQL), region bom (Mumbai) ────────────────────────────
# Local dev: file:local.db   |   Cloud: libsql://<db>-<org>.turso.io
DATABASE_URL=file:local.db
# Empty for local file DB; required for cloud Turso.
DATABASE_AUTH_TOKEN=

# ── Field encryption (AES-256-GCM) ───────────────────────────────────────────
# 32 bytes, base64. Generate with: openssl rand -base64 32
# Add ENCRYPTION_KEY_V2, _V3... when rotating. `*_key_version` columns select one.
ENCRYPTION_KEY_V1=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
# Optional override; defaults to the pinned Sonnet build (ARCHITECTURE §8.1/§15).
AI_MODEL=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=pathconsult@aiims-pilot.in

# ── Storage (Vercel Blob) ────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Cron protection ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 ; Vercel Cron sends this as a bearer token.
CRON_SECRET=

# ── Bootstrap admin (optional escape hatch) ──────────────────────────────────
# Any user signing in with this exact email is auto-promoted to active admin.
# Useful on a fresh deploy when no admin exists yet.
BOOTSTRAP_ADMIN_EMAIL=

# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
